# Podfile for MediaCCC iOS app
platform :ios, '16.0'
use_frameworks! :linkage => :static

target 'iosApp' do
  # Add the shared module as a local pod
  pod 'shared', :path => '../shared'

  pod 'google-cast-sdk', '~> 4.8'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
    end
  end

  # Add direct paths into the GoogleCast xcframework so the module is always
  # findable (even before the xcframeworks copy‑script runs).
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.xcconfigs.each do |config_name, config|
      xcfw = '${PODS_ROOT}/google-cast-sdk/GoogleCast.xcframework'
      fsp = config.attributes['FRAMEWORK_SEARCH_PATHS'] || '$(inherited)'
      fsp = "#{fsp} \"#{xcfw}/ios-arm64\" \"#{xcfw}/ios-arm64_x86_64-simulator\""
      config.attributes['FRAMEWORK_SEARCH_PATHS'] = fsp
      xcconfig_path = aggregate_target.xcconfig_path(config_name)
      config.save_as(xcconfig_path)
    end
  end
end

